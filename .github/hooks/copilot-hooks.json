{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "./.github/hooks/scripts/session-start.sh",
        "windows": "powershell -File .github\\hooks\\scripts\\session-start.ps1",
        "timeout": 10
      },
      {
        "type": "command",
        "command": "./.github/hooks/scripts/pulse.sh --trigger session_start",
        "windows": "powershell -File .github\\hooks\\scripts\\pulse.ps1 -Trigger session_start",
        "timeout": 5
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "./.github/hooks/scripts/pulse.sh --trigger user_prompt",
        "windows": "powershell -File .github\\hooks\\scripts\\pulse.ps1 -Trigger user_prompt",
        "timeout": 3
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "./.github/hooks/scripts/guard-destructive.sh",
        "windows": "powershell -File .github\\hooks\\scripts\\guard-destructive.ps1",
        "timeout": 5
      },
      {
        "type": "command",
        "command": "./.github/hooks/scripts/pulse.sh --trigger pre_tool",
        "windows": "powershell -File .github\\hooks\\scripts\\pulse.ps1 -Trigger pre_tool",
        "timeout": 4
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "./.github/hooks/scripts/post-edit-lint.sh",
        "windows": "powershell -File .github\\hooks\\scripts\\post-edit-lint.ps1",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "./.github/hooks/scripts/pulse.sh --trigger soft_post_tool",
        "windows": "powershell -File .github\\hooks\\scripts\\pulse.ps1 -Trigger soft_post_tool",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "./.github/hooks/scripts/scan-secrets.sh",
        "windows": "powershell -File .github\\hooks\\scripts\\scan-secrets.ps1",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "./.github/hooks/scripts/pulse.sh --trigger stop",
        "windows": "powershell -File .github\\hooks\\scripts\\pulse.ps1 -Trigger stop",
        "timeout": 5
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "./.github/hooks/scripts/save-context.sh",
        "windows": "powershell -File .github\\hooks\\scripts\\save-context.ps1",
        "timeout": 10
      },
      {
        "type": "command",
        "command": "./.github/hooks/scripts/pulse.sh --trigger compaction",
        "windows": "powershell -File .github\\hooks\\scripts\\pulse.ps1 -Trigger compaction",
        "timeout": 5
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "./.github/hooks/scripts/subagent-start.sh",
        "windows": "powershell -File .github\\hooks\\scripts\\subagent-start.ps1",
        "timeout": 5
      }
    ],
    "SubagentStop": [
      {
        "type": "command",
        "command": "./.github/hooks/scripts/subagent-stop.sh",
        "windows": "powershell -File .github\\hooks\\scripts\\subagent-stop.ps1",
        "timeout": 5
      }
    ]
  }
}
